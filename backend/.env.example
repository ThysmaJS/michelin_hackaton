# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Origine autorisée pour le CORS (frontend Vite par défaut).
FRONTEND_ORIGIN=http://localhost:5173

# ─── PostgreSQL (consommé par docker-compose ET par Prisma) ────
POSTGRES_USER=michelin
POSTGRES_PASSWORD=michelin
POSTGRES_DB=michelin_velo
# Port publié côté hôte. Mettre 5433 (ou autre) si un PostgreSQL local occupe déjà 5432.
POSTGRES_PORT=5433

# URL de connexion Prisma — doit refléter les variables POSTGRES_* ci-dessus.
DATABASE_URL=postgresql://michelin:michelin@localhost:5433/michelin_velo?schema=public

# ─── pgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@michelin.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ─── Rate limiting (throttler) ─────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
